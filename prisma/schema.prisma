generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
  url          = env("DATABASE_URL")
}

model TireRepairShop {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(128)
  longitude  Float    @unique @db.Double
  latitude   Float    @unique @db.Double
  rating     Int?     @db.UnsignedTinyInt
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  visits Trip[]

  @@map("tire_repair_shops")
}

model Rating {
  id         Int      @id @default(autoincrement())
  star       Int?     @db.UnsignedTinyInt
  created_at DateTime @default(now())

  trip Trip?

  @@map("ratings")
}

model Review {
  id         Int      @id @default(autoincrement())
  review     String?  @db.Text
  created_at DateTime @default(now())

  trip Trip?

  @@map("reviews")
}

enum TripStatus {
  completed
  cancelled
  onprogress
}

model Trip {
  id                  Int        @id @default(autoincrement())
  user_id             String     @db.VarChar(50)
  tire_repair_shop_id Int
  review_id           Int?       @unique
  rating_id           Int?       @unique
  status              TripStatus @default(onprogress)
  created_at          DateTime   @default(now())

  detail      TripDetail?
  rating      Rating?        @relation(fields: [rating_id], references: [id], onDelete: SetNull)
  review      Review?        @relation(fields: [review_id], references: [id], onDelete: SetNull)
  destination TireRepairShop @relation(fields: [tire_repair_shop_id], references: [id])

  @@index([rating_id])
  @@index([review_id])
  @@index([tire_repair_shop_id])
  @@map("trips")
}

model TripDetail {
  id                    Int   @id @default(autoincrement())
  trip_id               Int   @unique
  duration              Int   @db.UnsignedSmallInt
  distance              Float @db.Float
  coords_to_destination Json

  trip Trip @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@index([trip_id])
  @@map("trip_details")
}
